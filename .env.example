# =============================================================================
# Machine-specific environment configuration for In-Place TTT
# Copy this file to .env and modify values for your machine:
#   cp .env.example .env
# =============================================================================

# Python environment directory (choose one)
# Option 1: Virtual environment (recommended for local development)
VENV_DIR=
# Option 2: Conda environment (alternative, used if VENV_DIR is empty)
# Examples:
#   CONDA_ENV_DIR=$HOME/miniconda3/envs/ttt
#   CONDA_ENV_DIR=/path/to/conda/envs/ttt
CONDA_ENV_DIR=

# Cache directories (optional, defaults to $PROJECT_ROOT/.cache/{pip,tmp,huggingface})
PIP_CACHE_DIR=
TMPDIR=
HF_HOME=

# GPU devices to use for training (optional, defaults to all GPUs)
# Example for 8 GPUs: CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
CUDA_VISIBLE_DEVICES=

# NCCL timeout in seconds (optional, defaults to 1800)
NCCL_TIMEOUT=1800

# Weights & Biases API key (optional, only needed if use_wandb=true)
# Find yours at https://wandb.ai/authorize
WANDB_API_KEY=

# HuggingFace token (optional, only needed for gated models)
HUGGINGFACE_TOKEN=
